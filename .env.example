# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/nextrade.db

# Binance Testnet API Keys (Spot)
# Get keys from: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# Binance Testnet URLs
# URLs actualizadas desde Nov 2025 (testnet.binance.vision → demo-api.binance.com)
# Solo se usan cuando DATA_SOURCE=real y hay API keys configuradas
BINANCE_REST_URL=https://demo-api.binance.com
BINANCE_WS_URL=https://demo-ws-api.binance.com

# Data Source Mode
# real = Uses CCXT with Binance Testnet for market data
# simulated = Generates simulated data locally
DATA_SOURCE=real

# Trading Config
MIN_ORDER_USDT=5
MAX_ORDERS_PER_USER=50
MAKER_FEE=0.001
TAKER_FEE=0.001
